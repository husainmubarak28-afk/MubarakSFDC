<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Prevent_Zero_Or_Negative_Age</fullName>
    <active>true</active>
    <description>Age should e greater than zero</description>
    <errorConditionFormula>Age__c  &lt;= 0</errorConditionFormula>
    <errorDisplayField>Age__c</errorDisplayField>
    <errorMessage>Age should be greater than Zero.</errorMessage>
</ValidationRule>
